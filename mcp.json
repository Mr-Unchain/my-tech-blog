{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "microcms-document": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y microcms-document-mcp-server"
      ],
      "env": {}
    },
    "microcms": {
      "command": "npx",
      "args": [
        "-y",
        "microcms-mcp-server@latest",
        "--service-id",
        "${MICROCMS_SERVICE_ID}",
        "--api-key",
        "${MICROCMS_API_KEY}"
      ]
    }
  }
}
