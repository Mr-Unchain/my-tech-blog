---
/**
 * ArticleNavigation - 前後の記事ナビゲーション
 *
 * 記事下部に表示される、前後の記事へのナビゲーションリンク
 * 公開日順で前後の記事を表示
 */

interface Article {
  id: string;
  title: string;
  publishedAt?: string;
  eyecatch?: { url: string };
}

interface Props {
  currentId: string;
  allArticles: Article[];
}

const { currentId, allArticles } = Astro.props;

// 公開日順にソート
const sortedArticles = [...allArticles].sort((a, b) => {
  const dateA = new Date(a.publishedAt || 0).getTime();
  const dateB = new Date(b.publishedAt || 0).getTime();
  return dateB - dateA; // 新しい順
});

// 現在の記事のインデックスを取得
const currentIndex = sortedArticles.findIndex((article) => article.id === currentId);

// 前後の記事を取得（新しい順なので、prevは新しい記事、nextは古い記事）
const prevArticle = currentIndex > 0 ? sortedArticles[currentIndex - 1] : null;
const nextArticle = currentIndex < sortedArticles.length - 1 ? sortedArticles[currentIndex + 1] : null;
---

{(prevArticle || nextArticle) && (
  <nav class="article-navigation" aria-label="記事ナビゲーション">
    <div class="nav-grid">
      {/* 前の記事（より新しい記事） */}
      <div class="nav-item nav-prev">
        {prevArticle ? (
          <a href={`/blog/${prevArticle.id}/`} class="nav-link group">
            <span class="nav-direction">
              <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6" />
              </svg>
              <span>前の記事</span>
            </span>
            <span class="nav-title group-hover:text-cyan-400">{prevArticle.title}</span>
          </a>
        ) : (
          <div class="nav-placeholder" />
        )}
      </div>

      {/* 次の記事（より古い記事） */}
      <div class="nav-item nav-next">
        {nextArticle ? (
          <a href={`/blog/${nextArticle.id}/`} class="nav-link group">
            <span class="nav-direction">
              <span>次の記事</span>
              <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6" />
              </svg>
            </span>
            <span class="nav-title group-hover:text-cyan-400">{nextArticle.title}</span>
          </a>
        ) : (
          <div class="nav-placeholder" />
        )}
      </div>
    </div>
  </nav>
)}

<style>
  .article-navigation {
    @apply mt-10 pt-8 border-t border-slate-700/50;
  }

  .nav-grid {
    @apply grid grid-cols-1 md:grid-cols-2 gap-4;
  }

  .nav-item {
    @apply flex;
  }

  .nav-prev {
    @apply justify-start;
  }

  .nav-next {
    @apply justify-end md:text-right;
  }

  .nav-link {
    @apply flex flex-col gap-2 p-4 rounded-xl;
    @apply bg-slate-800/50 hover:bg-slate-700/50;
    @apply border border-slate-700/50 hover:border-cyan-500/30;
    @apply transition-all duration-200;
    @apply max-w-full md:max-w-[90%];
    text-decoration: none;
  }

  .nav-direction {
    @apply flex items-center gap-1 text-xs text-slate-400 font-medium;
  }

  .nav-next .nav-direction {
    @apply justify-end;
  }

  .nav-arrow {
    @apply w-4 h-4;
  }

  .nav-title {
    @apply text-sm font-medium text-slate-200 leading-snug;
    @apply transition-colors duration-200;
    @apply line-clamp-2;
  }

  .nav-placeholder {
    @apply hidden md:block;
  }

  /* テキストクランプ */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
