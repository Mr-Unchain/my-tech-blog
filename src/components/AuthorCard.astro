---
/**
 * AuthorCard - 著者情報カード
 *
 * 記事ページの右サイドバー（目次の上）に表示される著者情報カード
 * Zenn.devを参考にしたデザイン
 *
 * 含める要素:
 * - アバター画像
 * - 著者名
 * - 短い自己紹介
 * - SNSリンク（X、GitHub）
 */

import { getProfile } from "../lib/microcms";

// プロフィール情報を取得
const profile = await getProfile();
---

<div class="author-card bg-slate-700/60 p-5 rounded-xl border border-slate-600/50 shadow-lg backdrop-blur-sm mb-4">
  {/* アバターと名前 */}
  <div class="flex items-center gap-4 mb-3">
    {profile.avatar?.url ? (
      <img
        src={`${profile.avatar.url}?w=80&h=80&fit=crop`}
        alt={`${profile.name}のアバター`}
        width={48}
        height={48}
        class="w-12 h-12 rounded-full ring-2 ring-cyan-400/40 object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-12 h-12 rounded-full bg-slate-600 ring-2 ring-cyan-400/40 flex items-center justify-center">
        <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h4 class="text-white font-bold text-base truncate">{profile.name || "著者"}</h4>
      <span class="text-slate-400 text-xs">Author</span>
    </div>
  </div>

  {/* 自己紹介 */}
  {profile.description && (
    <p class="text-slate-300 text-sm leading-relaxed mb-4 line-clamp-3">
      {profile.description}
    </p>
  )}

  {/* SNSリンク */}
  <div class="flex items-center gap-3">
    {profile.xUrl && (
      <a
        href={profile.xUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center w-9 h-9 rounded-full bg-slate-600/50 hover:bg-cyan-500/20 border border-slate-500/30 hover:border-cyan-400/50 transition-all duration-200"
        aria-label="Xでフォロー"
        title="Xでフォロー"
      >
        <svg
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 text-slate-400 group-hover:text-cyan-400 transition-colors"
        >
          <path d="M18.9 2H22l-7.7 8.8L23.5 22H16l-5.2-6.8L4.8 22H2l8.3-9.5L.7 2h7l4.7 6.2L18.9 2z"/>
        </svg>
      </a>
    )}
    {profile.githubUrl && (
      <a
        href={profile.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-center w-9 h-9 rounded-full bg-slate-600/50 hover:bg-slate-500/30 border border-slate-500/30 hover:border-slate-400/50 transition-all duration-200"
        aria-label="GitHubでフォロー"
        title="GitHubでフォロー"
      >
        <svg
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 text-slate-400 group-hover:text-slate-200 transition-colors"
        >
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    )}

    {/* プロフィールページへのリンク */}
    <a
      href="/profile"
      class="ml-auto text-xs text-slate-400 hover:text-cyan-400 transition-colors flex items-center gap-1"
    >
      <span>詳細を見る</span>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>

<style>
  /* 3行で切り詰め */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
