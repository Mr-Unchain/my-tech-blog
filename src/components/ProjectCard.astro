---
// src/components/ProjectCard.astro
import type { Project } from "../lib/microcms";

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const techStack = project.techStack || [];
const hasThumbnail = Boolean(project.thumbnail?.url);
const hasAchievements = Boolean(project.achievements);
const linkLabel = project.link?.includes("github.com")
  ? "GitHub"
  : "詳細を見る";
---

<article
  class="group relative flex flex-col bg-gradient-to-br from-slate-800/90 to-slate-900/90 border border-slate-700/60 rounded-2xl p-6 shadow-xl shadow-cyan-500/5 hover:shadow-2xl hover:shadow-cyan-500/20 transition-all duration-500 overflow-hidden hover:scale-[1.02] hover:-translate-y-1"
>
  <!-- Animated gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-r from-cyan-500/10 via-transparent to-blue-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
  >
  </div>

  <!-- Gradient border effect on hover -->
  <div
    class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
    style="background: linear-gradient(135deg, rgba(34, 211, 238, 0.3) 0%, rgba(59, 130, 246, 0.3) 100%); padding: 1px; -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude;"
  >
  </div>

  <div class="relative z-10 space-y-4">
    <div class="flex items-start gap-4">
      {
        hasThumbnail ? (
          <div class="relative group/thumb">
            <img
              src={project.thumbnail!.url}
              alt={`${project.title}のサムネイル`}
              class="w-20 h-20 rounded-xl object-cover ring-2 ring-cyan-500/30 shadow-lg group-hover:ring-cyan-400/50 transition-all duration-300"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          </div>
        ) : (
          <div class="w-20 h-20 rounded-xl bg-gradient-to-br from-slate-700/70 to-slate-800/70 border border-slate-600/70 flex items-center justify-center text-slate-300 font-bold text-lg shadow-lg group-hover:border-cyan-500/50 transition-all duration-300">
            {project.title.slice(0, 2)}
          </div>
        )
      }
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          {
            project.period && (
              <span class="text-xs px-3 py-1.5 rounded-full bg-slate-700/70 border border-slate-600/70 text-slate-200 shadow-sm group-hover:border-slate-500/70 transition-colors duration-300">
                {project.period}
              </span>
            )
          }
          {
            project.role && (
              <span class="text-xs px-3 py-1.5 rounded-full bg-gradient-to-r from-cyan-500/15 to-blue-500/15 border border-cyan-500/30 text-cyan-200 font-semibold shadow-sm shadow-cyan-500/10 group-hover:border-cyan-400/50 group-hover:shadow-cyan-500/20 transition-all duration-300">
                {project.role}
              </span>
            )
          }
        </div>
        <h3
          class="mt-2 text-xl font-bold bg-gradient-to-r from-white to-cyan-100 bg-clip-text text-transparent group-hover:from-cyan-100 group-hover:to-blue-100 transition-all duration-300"
        >
          {project.title}
        </h3>
        {
          project.summary && (
            <div
              class="mt-2 text-slate-300 text-sm leading-relaxed line-clamp-3 prose prose-invert prose-sm max-w-none group-hover:text-slate-200 transition-colors duration-300"
              set:html={project.summary}
            />
          )
        }
      </div>
    </div>

    {
      techStack.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {techStack.map((tech) => (
            <span class="text-xs px-3 py-1.5 rounded-full bg-slate-800/80 border border-slate-700/70 text-slate-200 shadow-sm hover:bg-slate-700/80 hover:border-cyan-500/40 hover:text-cyan-200 transition-all duration-300 cursor-default">
              {tech}
            </span>
          ))}
        </div>
      )
    }

    {
      hasAchievements && (
        <div class="rounded-xl border border-cyan-500/30 bg-gradient-to-br from-cyan-500/10 to-blue-500/10 p-4 text-sm text-cyan-50 shadow-inner shadow-cyan-500/20 group-hover:border-cyan-400/40 group-hover:shadow-cyan-500/30 transition-all duration-300">
          <p class="font-semibold text-cyan-100 mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            担当領域・成果
          </p>
          <div
            class="leading-relaxed text-cyan-50/90 prose prose-invert prose-sm max-w-none"
            set:html={project.achievements}
          />
        </div>
      )
    }

    {
      project.link && (
        <div class="flex items-center justify-between pt-2 border-t border-slate-700/50">
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-cyan-300 hover:text-cyan-100 font-semibold group/link transition-colors duration-300"
            aria-label={`${project.title} の詳細リンク`}
          >
            <span>{linkLabel}</span>
            <svg
              class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.5 4.5h6v6m0-6L10 14l-3 3m12-12L14 10"
              />
            </svg>
          </a>
          <div class="text-xs text-slate-400 flex items-center gap-1.5">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            {new Date(
              project.updatedAt || project.createdAt || new Date(),
            ).toLocaleDateString("ja-JP")}
          </div>
        </div>
      )
    }
  </div>
</article>
